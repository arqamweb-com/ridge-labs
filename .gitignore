# ── Dependencies ─────────────────────────────────────────────
node_modules/
.npm/

# ── Build artifacts & backups ────────────────────────────────
# Keep the compiled assets/css/styles.css tracked (the theme ships
# with it), but ignore backups, source maps and Tailwind's cache.
*.css.bak
*.css.map
.tailwindcss-cache/

# ── Logs ─────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# ── Editor / IDE ─────────────────────────────────────────────
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# ── OS files ─────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── Environment ──────────────────────────────────────────────
.env
.env.local
.env.*.local
