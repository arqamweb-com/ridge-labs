{
  "name": "ridge-labs-2",
  "version": "1.0.0",
  "description": "Ridge Labs WordPress theme — Tailwind CSS v4 build pipeline",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i ./assets/css/src/tailwind.css -o ./assets/css/styles.css --minify",
    "watch:css": "tailwindcss -i ./assets/css/src/tailwind.css -o ./assets/css/styles.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.0",
    "tailwindcss": "^4.1.0"
  }
}
